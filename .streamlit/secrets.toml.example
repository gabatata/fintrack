# EXEMPLO de secrets. NAO coloque dados reais aqui (este arquivo VAI pro git).
#
# - LOCAL: copie para ".streamlit/secrets.toml" e preencha (esse arquivo e ignorado pelo git).
#          So precisa se quiser testar a sincronizacao com a nuvem localmente.
# - STREAMLIT CLOUD: cole este conteudo (preenchido) em Settings -> Secrets.
#
# A "key" e a chave service_role do Supabase (Project Settings -> API).

[supabase]
url = "https://SEU-PROJETO.supabase.co"
key = "SUA_SERVICE_ROLE_KEY"
bucket = "fintrack"
db_object = "fintrack.db"
